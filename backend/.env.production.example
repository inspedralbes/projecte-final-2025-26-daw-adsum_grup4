# ===========================================
# ADSUM - Configuración Producción
# ===========================================
# IMPORTANTE: Copiar a .env y rellenar valores reales

# Puerto del servidor
PORT=3000

# Base de Datos (MySQL) - NO EXPONER AL EXTERIOR
DB_HOST=db
DB_PORT=3306
DB_USERNAME=adsum_user
DB_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO_MUY_LARGO
DB_NAME=adsum_db

# Seguridad JWT - GENERAR CLAVE MUY LARGA Y ALEATORIA
# Ejemplo: openssl rand -base64 64
JWT_SECRET=GENERA_UNA_CLAVE_MUY_LARGA_Y_COMPLEJA_AQUI

# URL del frontend (para CORS)
FRONTEND_URL=https://adsum.daw.inspedralbes.cat

# Entorno
NODE_ENV=production

# Nivel de logging: error, warn, info, debug
LOG_LEVEL=info